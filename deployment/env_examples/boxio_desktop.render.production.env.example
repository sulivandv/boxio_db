# Boxio Desktop - produção Fase 1 com Render + Neon
# Troque a URL pela URL final gerada no Render.

BOXIO_DB_MODE=postgresql
BOXIO_DB_SCHEMA=boxio
BOXIO_DATABASE_URL=postgresql+psycopg://boxio_app_user:SENHA_FORTE@HOST_NEON/neondb?sslmode=require

BOXIO_LICENSE_SERVER_URL=https://boxio-license-server.onrender.com
BOXIO_LICENSE_OFFLINE_GRACE_DAYS=7
BOXIO_LICENSE_TIMEOUT=20
